generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}




model Snippet {
  id        Int       @id @default(autoincrement())
  title     String
  code      String
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  comments  Comment[]
  notifications Notification[]
}

model Comment {
  id        String    @id @default(cuid())
  content   String
  createdAt DateTime  @default(now())
  
  snippetId Int
  snippet   Snippet   @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  // Self-relation for Nested Replies
  parentId  String?
  parent    Comment?  @relation("ReplyToComment", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("ReplyToComment")
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  name     String?
  password String?   // <--- Make sure this line exists
  snippets Snippet[]
  comments Comment[]
  notifications Notification[] @relation("ReceivedNotifications")
}




model Notification {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  isRead      Boolean  @default(false)
  
  // Who performed the action (the commenter)
  actorName   String
  
  // The owner of the snippet
  userId      String
  user        User     @relation("ReceivedNotifications", fields: [userId], references: [id])
  
  // Link to the snippet for redirection
  snippetId   Int
  snippet     Snippet  @relation(fields: [snippetId], references: [id], onDelete: Cascade)
}






